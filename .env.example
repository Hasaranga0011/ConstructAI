# ConstructAI Email Configuration
# Copy this file to .env and fill in your credentials

# Email Configuration (for password reset)
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Get your App Password:
# 1. Go to: https://myaccount.google.com
# 2. Left sidebar: Security
# 3. Search: App passwords
# 4. Select Mail & Windows
# 5. Generate app password (16 characters with spaces)
# 6. Copy the password and paste here (remove spaces)

# Example:
# EMAIL_SENDER=myemail@gmail.com
# EMAIL_PASSWORD=abcdefghijklmnop
